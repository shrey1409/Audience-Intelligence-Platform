# ─── Database ───────────────────────────────────────────────
POSTGRES_URL=postgresql://aip_user:aip_password@localhost:5432/audience_intelligence
DB_SCHEMA=public

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── MLflow ─────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=audience_intelligence

# ─── API ────────────────────────────────────────────────────
API_KEY=replace-with-secure-random-key
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# ─── Google BigQuery (GA4 source) ───────────────────────────
BIGQUERY_PROJECT=your-gcp-project-id
BIGQUERY_DATASET=analytics
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# ─── Client ─────────────────────────────────────────────────
CLIENT_NAME=nypost

# ─── Pipeline ───────────────────────────────────────────────
AIRFLOW_HOME=./airflow
PIPELINE_SCHEDULE=@weekly

# ─── Environment ────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
