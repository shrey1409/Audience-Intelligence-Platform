# Copy to .env and fill in real values. Never commit .env.
# Uses Pydantic env_nested_delimiter="__" — e.g. DATABASE__URL maps to settings.database.url

# ─── Required — no YAML defaults; ValidationError at startup if absent ─────────
DATABASE__URL=postgresql://aip_user:changeme@localhost:5432/audience_intelligence
REDIS__URL=redis://localhost:6379/0
MLFLOW__TRACKING_URI=http://localhost:5000
API__API_KEYS=["dev-api-key-001"]
API__ADMIN_API_KEY=dev-admin-key-001

# ─── Optional — override YAML defaults ─────────────────────────────────────────
DATABASE__SCHEMA=public
APP_ENV=development
CLIENT_NAME=
LOG_LEVEL=INFO

# ─── Docker Compose ─────────────────────────────────────────────────────────────
# Must match the password in DATABASE__URL
POSTGRES_PASSWORD=changeme

# ─── Google BigQuery (GA4 source — Phase 6) ────────────────────────────────────
BIGQUERY_PROJECT=your-gcp-project-id
BIGQUERY_DATASET=analytics_XXXXXXXX
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
